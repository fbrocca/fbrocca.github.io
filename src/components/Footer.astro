---
const year = new Date().getFullYear();
---
<footer class="footer">
  <hr class="glow-line" />
  <div class="container inner">
    <div>
      <p class="mono muted">© {year} Fabio Brocca</p>
      <p class="mono tagline">Built in a galaxy not so far away.</p>
    </div>
    <ul class="social">
      <li><a href="https://www.linkedin.com/in/fabiobrocca" target="_blank" rel="noopener">LinkedIn</a></li>
      <li><a href="/rss.xml">RSS</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
  }

  .inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    padding-bottom: 2.5rem;
  }

  .inner p {
    margin: 0;
    font-size: 0.8rem;
  }

  .tagline {
    color: var(--faint);
    margin-top: 0.3rem !important;
  }

  .social {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .social a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .social a:hover {
    color: var(--accent-soft);
  }
</style>
