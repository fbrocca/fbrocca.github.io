---
// Renders the real image when the file exists under public/, otherwise a
// styled placeholder telling Fabio exactly which file to drop in. The check
// happens at build time, so swapping a placeholder is: add file, rebuild.
// Photos render normally in COLOR mode and dithered-monochrome in 1-BIT.
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  src: string;          // e.g. "/images/journey/msc.jpg"
  alt: string;
  label?: string;       // placeholder caption, e.g. "MSC years photo"
  aspect?: string;      // CSS aspect-ratio, e.g. "4 / 3"
  class?: string;
}

const { src, alt, label = alt, aspect = '4 / 3', class: className } = Astro.props;
const exists = fs.existsSync(path.join(process.cwd(), 'public', src));
---
{exists ? (
  <img src={src} alt={alt} loading="lazy" class:list={['mac-photo', className]} style={`aspect-ratio: ${aspect};`} />
) : (
  <div class:list={['mac-photo', 'placeholder', className]} style={`aspect-ratio: ${aspect};`} role="img" aria-label={alt}>
    <span class="ph-label">{label}</span>
    <span class="ph-path">{src}</span>
  </div>
)}
