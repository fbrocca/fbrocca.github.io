---
// Animated starfield background. Fixed behind all content; slow parallax
// drift with occasional twinkle. Falls back to a static render when the
// visitor prefers reduced motion.
---
<canvas id="starfield" aria-hidden="true"></canvas>

<style>
  #starfield {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    background: radial-gradient(ellipse at 50% -20%, #10101c 0%, var(--bg) 60%);
  }
</style>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface Star {
    x: number;
    y: number;
    r: number;
    speed: number;
    phase: number;
    twinkle: number;
  }

  let stars: Star[] = [];
  let w = 0;
  let h = 0;

  function seed() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    const count = Math.min(260, Math.floor((w * h) / 6000));
    stars = Array.from({ length: count }, () => ({
      x: Math.random() * w,
      y: Math.random() * h,
      r: Math.random() * 1.3 + 0.2,
      speed: Math.random() * 0.05 + 0.01,
      phase: Math.random() * Math.PI * 2,
      twinkle: Math.random() * 0.02 + 0.004,
    }));
  }

  function draw(t: number) {
    ctx.clearRect(0, 0, w, h);
    for (const s of stars) {
      const alpha = 0.45 + 0.45 * Math.sin(s.phase + t * s.twinkle);
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      // a few stars get the faintest blue tint
      ctx.fillStyle = s.r > 1.2
        ? `rgba(142, 194, 255, ${alpha})`
        : `rgba(233, 233, 242, ${alpha})`;
      ctx.fill();
      s.y -= s.speed;
      if (s.y < -2) {
        s.y = h + 2;
        s.x = Math.random() * w;
      }
    }
  }

  let frame = 0;
  function loop(t: number) {
    draw(t / 16);
    frame = requestAnimationFrame(loop);
  }

  seed();
  if (reduceMotion) {
    draw(0);
  } else {
    frame = requestAnimationFrame(loop);
  }

  window.addEventListener('resize', () => {
    cancelAnimationFrame(frame);
    seed();
    if (reduceMotion) {
      draw(0);
    } else {
      frame = requestAnimationFrame(loop);
    }
  });
</script>
