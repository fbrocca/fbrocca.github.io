---
import Desktop from '../layouts/Desktop.astro';
import MacWindow from '../components/MacWindow.astro';
---
<Desktop
  title="Page not found — Fabio Brocca"
  description="Error 404 — this page does not exist."
>
  <MacWindow title="System Error" id="win-404" style="left:440px; top:220px; width:440px">
    <div class="dlg-body">
      <svg width="40" height="44" viewBox="0 0 32 36" shape-rendering="crispEdges" aria-hidden="true">
        <circle cx="15" cy="22" r="12" fill="var(--c-warn,#fff)" stroke="#000" stroke-width="2"/>
        <rect x="12" y="8" width="6" height="4" fill="#fff" stroke="#000" stroke-width="1.6"/>
        <path d="M18 7 q6 -6 10 -3" fill="none" stroke="#000" stroke-width="2"/>
        <rect x="27" y="1" width="4" height="4" fill="#000"/>
        <rect x="12" y="19" width="2.4" height="5" fill="#000"/>
        <rect x="17" y="19" width="2.4" height="5" fill="#000"/>
      </svg>
      <div class="txt">
        <b style="font-family:var(--chicago); font-weight:normal">Sorry, a system error occurred.</b><br />
        Error 404: the page you asked for does not exist. It may have been moved,
        renamed, or dragged to the Trash.
      </div>
    </div>
    <div class="dlg-actions">
      <a class="mbtn default" href="/">Restart</a>
    </div>
  </MacWindow>
</Desktop>
