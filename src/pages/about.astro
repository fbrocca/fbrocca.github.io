---
import Desktop from '../layouts/Desktop.astro';
import MacWindow from '../components/MacWindow.astro';
import SmartImage from '../components/SmartImage.astro';
import worldmap from '../data/worldmap.json';

// equirectangular projection matching the world map data
const px = (lon: number) => ((lon + 180) / 360) * 1000;
const py = (lat: number) => ((78 - lat) / 136) * worldmap.H;

const stops = [
  { name: 'Padua, Italy', roman: 'I', x: px(11.88), y: py(45.41) },
  { name: 'Charleston, SC', roman: 'II', x: px(-79.93), y: py(32.78) },
  { name: 'Seattle, WA', roman: 'III', x: px(-122.33), y: py(47.61) },
  { name: 'Oslo, Norway', roman: 'IV', x: px(10.75), y: py(59.91) },
];

const routes = [
  `M${stops[0].x.toFixed(1)} ${stops[0].y.toFixed(1)} Q 400 42 ${stops[1].x.toFixed(1)} ${stops[1].y.toFixed(1)}`,
  `M${stops[1].x.toFixed(1)} ${stops[1].y.toFixed(1)} Q 208 96 ${stops[2].x.toFixed(1)} ${stops[2].y.toFixed(1)}`,
  `M${stops[2].x.toFixed(1)} ${stops[2].y.toFixed(1)} Q 345 6 ${stops[3].x.toFixed(1)} ${stops[3].y.toFixed(1)}`,
];

const chapters = [
  {
    label: 'Chapter I · 2012',
    title: 'Padua, Italy',
    image: '/images/journey/padua.jpg',
    imageLabel: 'Photo — early days / Italy',
    caption: 'Chapter I · Padua, 2012',
    body: [
      'I grew up in Italy and studied engineering at the University of Padua — one of the oldest universities in the world, where Galileo once taught. I left with a degree in industrial engineering and a conviction that the most interesting problems live where physical operations meet software.',
      'Global shipping turned out to be exactly that kind of problem.',
    ],
  },
  {
    label: 'Chapter II · 2013 — 2020',
    title: 'MSC — learning the ocean',
    image: '/images/journey/msc.jpg',
    imageLabel: 'Photo — MSC years',
    caption: 'Chapter II · MSC, Charleston, 2013 – 2020',
    body: [
      'I joined Mediterranean Shipping Company, the world’s largest container carrier, and worked my way up from the export desk: built and led a 17-person export team, then became P&L owner for MSC’s Southeast US region — the largest MSC office in North America, 350+ employees and $10M+ EBITDA a year, reporting to the CEO. Along the way I founded the MSC Academy, a leadership program that spread to six agencies.',
      'Then I moved from running operations to transforming them. As Director of Business Transformation I built MSC’s first data science and software product teams, launched a worldwide automation program that took on 50+ processes and returned $50M+ in annual savings, rolled out ERP and CRM platforms across ten countries, and stood up a 300-engineer technology center in Chennai.',
      'Seven years, four roles, one lesson: technology only matters if the people running the ships actually use it.',
    ],
  },
  {
    label: 'Chapter III · 2020 — 2024',
    title: 'Amazon — planet-scale product',
    image: '/images/journey/amazon.jpg',
    imageLabel: 'Photo — Amazon years',
    caption: 'Chapter III · Amazon, Seattle, 2020 – 2024',
    body: [
      'At Amazon I went deep on zero-to-one: as Senior Technical PM for Vehicle Telematics I built an AI/ML predictive maintenance product for the largest last-mile fleet in the world — telematics, edge computing, cameras, EV integrations — worth $100M+ in NPV, one of the largest single-product AI investments in Amazon transportation at the time.',
      'Then I went wide: as Head of Product for Global Transportation Technology I led a portfolio of 10+ products used by 30,000+ people across North America, Europe, and APAC, and served as worldwide product lead for Supply Chain Configuration Automation — the multi-year program optimizing Amazon’s fulfillment network that generated over $1B in ROI in 2022.',
      'While there, I also completed a Master’s in Data Science & Analytics at Georgia Tech. Nights and weekends. Would recommend, eventually.',
    ],
  },
  {
    label: 'Chapter IV · 2024 — present',
    title: 'Xeneta — bringing transparency to freight',
    image: '/images/journey/xeneta.jpg',
    imageLabel: 'Photo — Xeneta / Summit keynote',
    caption: 'Chapter IV · Xeneta, Oslo, 2024 – present',
    body: [
      'Today I’m the Chief Product Officer at Xeneta, the world’s largest ocean and air freight rate intelligence platform. I’m the company’s first CPO, and I lead a 40+ person organization spanning product management, UX design, product marketing, sales enablement, value engineering, and market intelligence across Europe, Asia, and the US.',
      'Since I joined we’ve grown ARR more than 30% year over year — by shipping agentic AI into procurement workflows (a freight industry first), launching industry-first financial derivatives, and expanding into new data products. I sit on the executive team, contribute to company strategy, M&A, and board work, and I still review products like a PM.',
    ],
  },
];

const ventures = [
  { name: 'Inperaco LLC', years: '2021 — present', role: 'Founder & Managing Partner', line: 'AI and supply chain technology consultancy.' },
  { name: 'Oxford Data Plan', years: '2025 — present', role: 'Advisor', line: 'Alternative data and data science for financial markets.' },
  { name: 'Reel Saber', years: '2023 — 2025 · exited', role: 'Founder', line: 'Cosplay hardware company. Yes — I founded, ran, and sold an actual lightsaber company. Check the Trash for what remains of the old website theme.' },
  { name: 'PM Circles', years: '2022 — 2024', role: 'Founder', line: 'Product management mentoring community, 1,000+ members.' },
  { name: 'College of Charleston', years: 'ongoing', role: 'Lecturer', line: 'MBA Leadership, Computer Science Data Analytics, Supply Chain Management.' },
];

const education = [
  'MS, Data Science & Analytics — Georgia Institute of Technology (2023)',
  'MBA, First Class Honors — Middlesex University, London (2018)',
  'BS, Engineering — University of Padua (2012)',
  'SVPG Product Management · MIT Supply Chain Design · Lean Six Sigma Green Belt',
];
---
<Desktop
  title="The Journey — Fabio Brocca"
  description="From the export desk at MSC to CPO at Xeneta, via planet-scale product at Amazon: the journey of a product executive in freight, logistics, and AI."
>
  <MacWindow
    title="The Map"
    id="win-map"
    style="left:calc(50vw - 20px); top:calc(50% + 16px); width:calc(50vw - 140px); height:calc(50% - 60px)"
    class="stagger-2"
  >
    <div class="fstatus" id="map-status">Chapter I · Padua, Italy</div>
    <svg id="jmap" viewBox={`0 0 1000 ${worldmap.H}`} preserveAspectRatio="xMidYMid slice" role="img" aria-label="World map following the journey: Padua, Charleston, Seattle, Oslo">
      <path class="mapdots" d={worldmap.dots} />
      {routes.map((d, i) => (
        <path class="jroute" id={`route-${i}`} d={d} />
      ))}
      {stops.map((s, i) => (
        <g class:list={['jstop', { active: i === 0, future: i !== 0 }]} data-i={i} data-name={s.name} data-roman={s.roman}>
          <circle class="ring" cx={s.x.toFixed(1)} cy={s.y.toFixed(1)} r="7" />
          <circle class="core" cx={s.x.toFixed(1)} cy={s.y.toFixed(1)} r="2.6" />
          <text
            x={(s.x + (s.name === 'Oslo, Norway' || s.name === 'Padua, Italy' ? 10 : -10)).toFixed(1)}
            y={(s.y + (s.name === 'Padua, Italy' ? 12 : 3)).toFixed(1)}
            text-anchor={s.name === 'Oslo, Norway' ? 'start' : s.name === 'Padua, Italy' ? 'middle' : 'end'}
          >{s.name.toUpperCase()}</text>
        </g>
      ))}
    </svg>
  </MacWindow>

  <MacWindow
    title="Photos"
    id="win-jphotos"
    style="left:calc(50vw - 20px); top:44px; width:calc(50vw - 140px); height:calc(50% - 44px)"
    class="stagger-2"
  >
    <div class="photo-stage">
      {chapters.map((c, i) => (
        <figure class:list={['jphoto', { show: i === 0 }]} data-photo={i}>
          <SmartImage src={c.image} alt={c.imageLabel} label={c.imageLabel} aspect="4 / 3" />
          <figcaption>{c.caption}</figcaption>
        </figure>
      ))}
    </div>
  </MacWindow>

  <MacWindow
    title="The Journey"
    id="win-journey"
    style="left:30px; top:44px; width:calc(50vw - 80px); height:calc(100% - 62px)"
    zoom={true}
  >
    <div class="ruler"></div>
    <div class="doc">
      <div class="post-head">
        <h1>From the dock to the board room</h1>
        <p class="meta">Fifteen-plus years building data-driven AI platforms in freight, logistics, and supply chain — told in four chapters. Watch the map.</p>
      </div>

      {chapters.map((c, i) => (
        <>
          <h2 data-stop={i}>{c.label} — {c.title}</h2>
          <div class="inline-photo">
            <SmartImage src={c.image} alt={c.imageLabel} label={c.imageLabel} aspect="4 / 3" />
          </div>
          {c.body.map((p) => <p>{p}</p>)}
        </>
      ))}

      <h2>Side quests — ventures, boards &amp; teaching</h2>
      <ul>
        {ventures.map((v) => (
          <li><b>{v.name}</b> ({v.years}) — {v.role}. {v.line}</li>
        ))}
      </ul>

      <h2>Education &amp; certifications</h2>
      <ul>
        {education.map((e) => <li>{e}</li>)}
      </ul>
    </div>
  </MacWindow>
</Desktop>

<style>
  /* larger reading size for the story */
  #win-journey .doc { font-size: 15px; line-height: 1.7; }
  #win-journey .doc :global(h2) { font-size: 18px; }
  #win-journey .doc :global(h1) { font-size: 21px; }

  /* photos live in their own window on desktop; inline only on phones */
  .inline-photo { display: none; }
  @media (max-width: 720px) {
    .inline-photo { display: block; margin: 6px 0 14px; }
  }

  /* ---- Photos window ---- */
  #win-jphotos :global(.wbody) { overflow: hidden; }
  .photo-stage { height: 100%; position: relative; }
  .jphoto {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 14px 16px 10px;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .jphoto.show { display: flex; animation: photo-in 0.5s ease; }
  @keyframes photo-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .jphoto :global(.mac-photo) {
    flex: 1;
    min-height: 0;
    width: auto;
    max-width: 100%;
    object-fit: cover;
  }
  .jphoto figcaption { flex: none; font-size: 12.5px; text-align: center; }

  /* ---- Map window ---- */
  #win-map :global(.wbody) { display: flex; flex-direction: column; overflow: hidden; }
  #jmap { flex: 1; min-height: 0; width: 100%; display: block; }

  .mapdots {
    stroke: #000;
    opacity: 0.22;
    stroke-width: 2.6;
    stroke-linecap: round;
    fill: none;
  }
  :global(html[data-scheme='color']) .mapdots { stroke: #33569c; opacity: 0.3; }

  /* the travel line, drawn progressively (dasharray/offset set by script) */
  .jroute {
    fill: none;
    stroke: #000;
    stroke-width: 1.6;
    stroke-linecap: round;
    transition: stroke-dashoffset 1.4s ease;
  }
  :global(html[data-scheme='color']) .jroute { stroke: #b03a2e; }

  .jstop .core { fill: #000; }
  .jstop .ring {
    fill: none;
    stroke: #000;
    stroke-width: 1.2;
    opacity: 0;
    transform-origin: center;
    transform-box: fill-box;
  }
  .jstop text {
    font-family: var(--chicago);
    font-size: 7.5px;
    letter-spacing: 0.06em;
    fill: #000;
    paint-order: stroke;
    stroke: #fff;
    stroke-width: 2.5px;
    stroke-linejoin: round;
  }
  .jstop.future { opacity: 0.3; }
  .jstop.active { opacity: 1; }
  .jstop.active .ring { opacity: 0.8; animation: stop-pulse 2.6s ease-out infinite; }
  :global(html[data-scheme='color']) .jstop.active .core { fill: #b03a2e; }
  :global(html[data-scheme='color']) .jstop.active .ring { stroke: #b03a2e; }

  @keyframes stop-pulse {
    0% { transform: scale(0.4); opacity: 0.9; }
    75% { transform: scale(1.9); opacity: 0; }
    100% { transform: scale(1.9); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .jroute { transition: none; }
    .jstop.active .ring { animation: none; opacity: 0.8; }
    .jphoto.show { animation: none; }
  }
</style>

<script>
  const svg = document.getElementById('jmap');
  const statusBar = document.getElementById('map-status');
  const wbody = document.querySelector('#win-journey .wbody');

  if (svg && statusBar && wbody) {
    const W = 1000;
    const H = (svg as unknown as SVGSVGElement).viewBox.baseVal.height;
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const stopEls = Array.from(svg.querySelectorAll<SVGGElement>('.jstop'));
    const stops = stopEls.map((g) => {
      const c = g.querySelector('circle.core')!;
      return {
        el: g,
        x: +c.getAttribute('cx')!,
        y: +c.getAttribute('cy')!,
        name: g.dataset.name!,
        roman: g.dataset.roman!,
      };
    });
    const photoEls = Array.from(document.querySelectorAll<HTMLElement>('.jphoto'));

    /* prepare the travel lines for draw-on animation */
    const routeEls = Array.from(svg.querySelectorAll<SVGPathElement>('.jroute'));
    routeEls.forEach((r) => {
      const len = r.getTotalLength();
      r.style.strokeDasharray = String(len);
      r.style.strokeDashoffset = String(len);
    });

    /* animated viewBox: pan & zoom toward the active stop */
    const ZOOM_W = 430;
    const ZOOM_H = (ZOOM_W / W) * H * 1.15;
    let cur = [0, 0, W, H];
    let target = [0, 0, W, H];
    let raf = 0;

    function viewFor(s: { x: number; y: number }) {
      const x = Math.max(0, Math.min(s.x - ZOOM_W / 2, W - ZOOM_W));
      const y = Math.max(0, Math.min(s.y - ZOOM_H / 2, H - ZOOM_H));
      return [x, y, ZOOM_W, ZOOM_H];
    }

    function step() {
      const k = reduced ? 1 : 0.07;
      let done = true;
      cur = cur.map((v, i) => {
        const n = v + (target[i] - v) * k;
        if (Math.abs(target[i] - n) > 0.3) done = false;
        return n;
      });
      if (done) cur = [...target];
      svg!.setAttribute('viewBox', cur.map((v) => v.toFixed(2)).join(' '));
      if (!done) raf = requestAnimationFrame(step);
    }

    let active = -1;
    function activate(i: number) {
      if (i === active) return;
      active = i;
      const s = stops[i];
      stops.forEach((st, n) => {
        st.el.classList.toggle('active', n === i);
        st.el.classList.toggle('future', n > i);
      });
      routeEls.forEach((r, n) => {
        r.style.strokeDashoffset = n < i ? '0' : r.style.strokeDasharray;
      });
      photoEls.forEach((p, n) => p.classList.toggle('show', n === i));
      statusBar!.textContent = `Chapter ${s.roman} · ${s.name}`;
      target = viewFor(s);
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(step);
    }

    /* follow the reader: whichever chapter heading crosses the upper part
       of the journey window sets the map's destination */
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) activate(+(e.target as HTMLElement).dataset.stop!);
        });
      },
      { root: wbody, rootMargin: '-10% 0px -60% 0px' }
    );
    document.querySelectorAll<HTMLElement>('[data-stop]').forEach((h) => io.observe(h));

    /* open on the full world, then fly to chapter one */
    setTimeout(() => activate(0), reduced ? 0 : 700);
  }
</script>
