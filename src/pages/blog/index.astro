---
import Desktop from '../../layouts/Desktop.astro';
import MacWindow from '../../components/MacWindow.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Desktop
  title="Writing — Fabio Brocca"
  description="Essays on product leadership, AI in supply chains, and building product organizations in complex industries."
>
  <MacWindow title="Writing" id="win-blog" style="left:300px; top:120px; width:580px" zoom={true}>
    <div class="fstatus">{posts.length} item{posts.length === 1 ? '' : 's'} · essays on product, AI &amp; supply chains · <a href="/rss.xml">RSS</a></div>
    <table class="flist">
      <thead><tr><th>Name</th><th>Date</th><th>Kind</th></tr></thead>
      <tbody>
        {posts.map((p) => (
          <tr class="rowlink" data-href={`/blog/${p.id}/`}>
            <td class="nm"><a href={`/blog/${p.id}/`}>{p.data.title}</a></td>
            <td class="dt">{fmt(p.data.date)}</td>
            <td>essay</td>
          </tr>
        ))}
      </tbody>
    </table>
  </MacWindow>
</Desktop>

<style>
  .rowlink { cursor: pointer; }
  .rowlink a { text-decoration: none; color: inherit; }
  .rowlink:hover td { background: #000; color: #fff; }
  :global(html[data-scheme='color']) .rowlink:hover td { background: var(--hl); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.rowlink').forEach((tr) => {
    tr.addEventListener('click', () => { location.href = tr.dataset.href!; });
  });
</script>
