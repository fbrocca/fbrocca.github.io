---
import Desktop from '../layouts/Desktop.astro';
import MacWindow from '../components/MacWindow.astro';
---
<Desktop
  title="Contact — Fabio Brocca"
  description="Get in touch with Fabio Brocca — Chief Product Officer, product and AI leader in freight, logistics, and supply chain."
>
  <MacWindow title="Contact" id="win-contact" style="left:400px; top:200px; width:440px">
    <div class="dlg-body">
      <svg class="i-mail" width="42" height="32" viewBox="0 0 30 24" shape-rendering="crispEdges" aria-hidden="true">
        <rect x="1" y="1" width="28" height="22" fill="var(--c-env,#fff)" stroke="#000" stroke-width="2"/>
        <path d="M1 1 L15 13 L29 1" fill="none" stroke="#000" stroke-width="2"/>
      </svg>
      <div class="txt">
        Product leadership, AI in supply chains, board work, speaking, or a good
        espresso recommendation — my inbox is open.
        <div class="addr">fabio@inperaco.com</div>
      </div>
    </div>
    <div class="dlg-actions">
      <a class="mbtn" href="https://www.linkedin.com/in/fabiobrocca/" target="_blank" rel="noopener">LinkedIn</a>
      <a class="mbtn default" href="mailto:fabio@inperaco.com">Send Email</a>
    </div>
  </MacWindow>
</Desktop>
