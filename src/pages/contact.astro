---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact — Fabio Brocca"
  description="Get in touch with Fabio Brocca — Chief Product Officer, product and AI leader in freight, logistics, and supply chain."
>
  <section class="section contact-section">
    <div class="container">
      <p class="section-label">// open a channel</p>
      <h1>Get in touch</h1>
      <p class="lede muted">
        Product leadership, AI in supply chains, board work, speaking, or a
        good espresso recommendation — my inbox is open.
      </p>

      <div class="channels">
        <a class="card channel" href="mailto:fabiobrocca@outlook.com">
          <div class="mono muted">email</div>
          <h3>fabiobrocca@outlook.com</h3>
          <p class="muted">Best for anything substantive.</p>
        </a>
        <a class="card channel" href="https://www.linkedin.com/in/fabiobrocca" target="_blank" rel="noopener">
          <div class="mono muted">linkedin</div>
          <h3>/in/fabiobrocca</h3>
          <p class="muted">Career conversations and connecting.</p>
        </a>
      </div>

      <p class="mono location muted">📍 Mount Pleasant, South Carolina — US</p>
    </div>
  </section>
</Base>

<style>
  .contact-section {
    min-height: 60vh;
  }

  .lede {
    font-size: 1.2rem;
    max-width: 36rem;
  }

  .channels {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
    max-width: 44rem;
  }

  .channel {
    color: var(--text);
    display: block;
  }

  .channel:hover {
    text-shadow: none;
  }

  .channel h3 {
    margin-bottom: 0.3em;
    word-break: break-all;
  }

  .location {
    margin-top: 2.5rem;
    font-size: 0.85rem;
  }
</style>
