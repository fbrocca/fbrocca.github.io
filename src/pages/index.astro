---
import Base from '../layouts/Base.astro';
import SmartImage from '../components/SmartImage.astro';
import { getCollection } from 'astro:content';
import media from '../data/media.json';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featured = media.filter((m) => m.featured);

const stats = [
  { value: '$1B+', label: 'ROI from supply chain automation at Amazon' },
  { value: '$100M+', label: 'NPV from a 0→1 AI product' },
  { value: '30%+', label: 'YoY ARR growth at Xeneta' },
  { value: '40+', label: 'person product org built & led' },
];

const highlights = [
  {
    company: 'Xeneta',
    role: 'Chief Product Officer',
    years: '2024 — present',
    line: 'Leading product for the world’s largest freight rate intelligence platform — agentic AI, industry-first derivatives, 500+ enterprise customers.',
  },
  {
    company: 'Amazon',
    role: 'Head of Product, Global Transportation Technology',
    years: '2020 — 2024',
    line: '10+ products, 30,000+ users, and the supply chain automation behind one of the largest fulfillment networks on Earth.',
  },
  {
    company: 'MSC',
    role: 'Director, Business Transformation',
    years: '2013 — 2020',
    line: 'Built the first data science and automation teams at the world’s largest container shipping company.',
  },
];
---
<Base
  title="Fabio Brocca — Chief Product Officer"
  description="Product executive with 15+ years building data-driven AI platforms in freight, logistics, and supply chain. CPO at Xeneta, formerly Amazon and MSC."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="section-label">// product executive</p>
        <h1>Fabio<br />Brocca</h1>
        <p class="tagline">
          Chief Product Officer. I build AI products and product orgs
          that move the world's freight.
        </p>
        <div class="hero-cta">
          <a class="btn btn--solid" href="/about/">The journey</a>
          <a class="btn" href="/contact/">Get in touch</a>
        </div>
      </div>
      <div class="hero-avatar">
        <SmartImage
          src="/images/avatar.gif"
          alt="Animated sci-fi style avatar of Fabio Brocca"
          label="Your Jedi-style avatar GIF"
          aspect="1 / 1"
          class="avatar-img"
        />
      </div>
    </div>
    <div class="scroll-hint mono" aria-hidden="true">▼</div>
  </section>

  <!-- Impact stats -->
  <section class="section">
    <div class="container">
      <div class="stats">
        {stats.map((s) => (
          <div class="stat">
            <div class="stat-value">{s.value}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Career highlights -->
  <section class="section">
    <div class="container">
      <p class="section-label">// the short version</p>
      <h2>Fifteen years moving atoms with bits</h2>
      <div class="highlights">
        {highlights.map((h) => (
          <article class="card">
            <div class="mono muted">{h.years}</div>
            <h3>{h.company}</h3>
            <p class="role">{h.role}</p>
            <p class="muted">{h.line}</p>
          </article>
        ))}
      </div>
      <p class="more-link"><a href="/about/">Read the full story →</a></p>
    </div>
  </section>

  <!-- Featured media -->
  <section class="section">
    <div class="container">
      <p class="section-label">// on air</p>
      <h2>Podcasts &amp; keynotes</h2>
      <div class="media-grid">
        {featured.map((m) => (
          <article class="card">
            <div class="mono muted">{m.show}</div>
            <h3>{m.title}</h3>
            <p class="muted">{m.summary}</p>
            {Object.entries(m.links).length > 0 && (
              <p class="media-links">
                {Object.entries(m.links).map(([name, url]) => (
                  <a href={url} target="_blank" rel="noopener" class="mono">{name} ↗</a>
                ))}
              </p>
            )}
          </article>
        ))}
      </div>
      <p class="more-link"><a href="/media/">All appearances →</a></p>
    </div>
  </section>

  <!-- Latest posts -->
  <section class="section">
    <div class="container">
      <p class="section-label">// transmissions</p>
      <h2>Latest writing</h2>
      {posts.length > 0 ? (
        <div class="posts">
          {posts.map((p) => (
            <a class="card post-card" href={`/blog/${p.id}/`}>
              <div class="mono muted">
                {p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </div>
              <h3>{p.data.title}</h3>
              <p class="muted">{p.data.description}</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="muted">First transmission coming soon.</p>
      )}
      <p class="more-link"><a href="/blog/">All posts →</a></p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container cta">
      <h2>Building something that moves the world?</h2>
      <p class="muted">I'm always glad to talk product, AI, and supply chains.</p>
      <a class="btn btn--solid" href="/contact/">Get in touch</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    min-height: calc(100vh - 4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-copy .tagline {
    font-size: 1.3rem;
    color: var(--muted);
    max-width: 30rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .hero-avatar {
    max-width: 22rem;
    justify-self: center;
    width: 100%;
  }

  :global(.avatar-img) {
    border-radius: 50% !important;
    box-shadow: 0 0 60px var(--accent-glow);
  }

  .scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--faint);
    animation: bob 2s ease-in-out infinite;
  }

  @keyframes bob {
    50% { transform: translateX(-50%) translateY(6px); }
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent-soft);
    text-shadow: 0 0 24px var(--accent-glow);
  }

  .stat-label {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.4;
    margin-top: 0.3rem;
  }

  .highlights,
  .media-grid,
  .posts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .role {
    color: var(--accent-soft);
    font-size: 0.95rem;
    margin-bottom: 0.5em;
  }

  .media-links {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    margin: 0;
  }

  .media-links a {
    font-size: 0.8rem;
  }

  .post-card {
    color: var(--text);
    display: block;
  }

  .post-card:hover {
    text-shadow: none;
  }

  .more-link {
    margin-top: 2rem;
    font-family: var(--font-heading);
  }

  .cta-section .cta {
    text-align: center;
    padding: 3rem 1.5rem;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-copy .tagline {
      margin: 0 auto;
    }

    .hero-cta {
      justify-content: center;
    }

    .hero-avatar {
      max-width: 14rem;
      order: -1;
    }

    .stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
