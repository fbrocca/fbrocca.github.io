---
import Desktop from '../layouts/Desktop.astro';
import MacWindow from '../components/MacWindow.astro';
import ResumeDoc from '../components/ResumeDoc.astro';
---
<Desktop
  title="Fabio Brocca — Chief Product Officer"
  description="Product executive with 15+ years building data-driven AI platforms in freight, logistics, and supply chain. CPO at Xeneta, formerly Amazon and MSC."
  boot={true}
>
  <MacWindow title="Résumé" id="win-resume" style="left:560px; top:64px; width:620px; height:640px" zoom={true} class="stagger-2">
    <ResumeDoc />
  </MacWindow>

  <MacWindow title="About Fabio" id="win-about" style="left:90px; top:70px; width:430px" pad={true}>
    <div class="about-top">
      <svg class="i-mac" width="52" height="68" viewBox="0 0 30 40" shape-rendering="crispEdges" aria-hidden="true">
        <rect x="1" y="1" width="28" height="34" fill="var(--c-body,#fff)" stroke="#000" stroke-width="2"/>
        <rect x="5" y="5" width="20" height="16" fill="var(--c-screen,#fff)" stroke="#000" stroke-width="2"/>
        <rect x="11" y="9" width="2" height="4" fill="#000"/>
        <rect x="17" y="9" width="2" height="4" fill="#000"/>
        <rect x="14" y="12" width="2" height="3" fill="#000"/>
        <rect x="10" y="16" width="2" height="2" fill="#000"/>
        <rect x="12" y="17" width="6" height="2" fill="#000"/>
        <rect x="18" y="16" width="2" height="2" fill="#000"/>
        <rect x="5" y="26" width="12" height="3" fill="#fff" stroke="#000" stroke-width="1.5"/>
        <rect x="21" y="26" width="4" height="3" fill="#fff" stroke="#000" stroke-width="1.5"/>
        <rect x="1" y="35" width="28" height="4" fill="var(--c-body,#fff)" stroke="#000" stroke-width="2"/>
      </svg>
      <div>
        <h1>Fabio Brocca</h1>
        <div class="sub">System Software: Chief Product Officer</div>
        <div class="sub">© Fabio Brocca 2011–2026</div>
      </div>
    </div>
    <div class="about-info">
      <b>Built-in Experience:</b> 15 years moving atoms with bits<br />
      <b>Networks Installed:</b> Ocean · Air · Road<br />
      <b>Largest Result:</b> $1B+ ROI from supply chain automation
    </div>
    <div class="ram">
      <div class="row"><span class="co">Xeneta</span><span class="bar"><i style="width:20%"></i></span><span class="yrs">2024 – now</span></div>
      <div class="row"><span class="co">Amazon</span><span class="bar"><i style="width:38%"></i></span><span class="yrs">2020 – 24</span></div>
      <div class="row"><span class="co">MSC</span><span class="bar"><i style="width:64%"></i></span><span class="yrs">2013 – 20</span></div>
    </div>
  </MacWindow>
</Desktop>
