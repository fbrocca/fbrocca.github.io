---
import Desktop from '../layouts/Desktop.astro';
import MacWindow from '../components/MacWindow.astro';
import media from '../data/media.json';
---
<Desktop
  title="Media — Fabio Brocca"
  description="Podcast appearances and keynotes by Fabio Brocca: Product Thinking with Melissa Perri, The Freight Debate, Out of the Box, and Xeneta Summit."
>
  <MacWindow title="Media" id="win-media" style="left:300px; top:70px; width:600px; height:620px" zoom={true}>
    <div class="fstatus">{media.length} items · podcasts &amp; keynotes</div>
    <div class="doc" style="max-width:none">
      {media.map((m) => (
        <div class="media-item">
          <h2>♪ {m.title}</h2>
          <p class="meta">{m.show} · {m.date} · {m.type}</p>
          <p>{m.summary}</p>
          {Object.entries(m.links).length > 0 && (
            <p class="media-links">
              {Object.entries(m.links).map(([name, url]) => (
                <a class="mbtn" href={url} target="_blank" rel="noopener">{name} ↗</a>
              ))}
            </p>
          )}
        </div>
      ))}
    </div>
  </MacWindow>
</Desktop>

<style>
  .media-item { border-bottom: 1px solid #000; padding-bottom: 14px; margin-bottom: 16px; }
  .media-item:last-child { border-bottom: 0; margin-bottom: 0; }
  .media-links { display: flex; gap: 10px; flex-wrap: wrap; }
  .media-links .mbtn { font-size: 12px; padding: 3px 12px; }
</style>
